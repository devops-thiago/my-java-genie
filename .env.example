LLM_API_KEY=your-api-key
LLM_BASE_URL=https://ollama.com/v1
LLM_MODEL_NAME=gpt-oss:120b-cloud
LLM_MAX_TOKENS=1024

# Used when the vector store is enabled
VECTOR_DB_URL=http://localhost:8000

# Sample documents for ingestion (HTML)
CORPUS_PATH=docs/specs/primitive-types-in-patterns-instanceof-switch-jls.html

# Cost / retrieval knobs
QUERY_TOP_K=5
INGEST_CHUNK_SIZE=1000
INGEST_CHUNK_OVERLAP=200

# OpenTelemetry (console by default; set OTEL_EXPORTER=otlp for a collector)
OTEL_ENABLED=true
OTEL_SERVICE_NAME=my-java-genie
OTEL_EXPORTER=logging
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
